# Logging for main.py (Python logging). WARNING shows data vendor fallback lines.
# LOG_LEVEL=WARNING

# Optional: override models when running main.py (defaults shown in main.py)
# LLM_PROVIDER=openrouter
# QUICK_THINK_LLM=openrouter/free
# DEEP_THINK_LLM=openrouter/free
#
# LLM HTTP client (OpenAI-compatible providers only): extra retries/timeouts
# LLM_MAX_RETRIES=4
# LLM_TIMEOUT=120
#
# When the gateway returns HTTP 200 with {"error": {...}} (e.g. OpenRouter 502), retry that many times
# LLM_PROVIDER_ERROR_MAX_ATTEMPTS=4
#
# Cap LLM completions per rolling 60 seconds (integer floor; shared across quick/deep and all nodes)
# LLM_RATE_LIMIT_RPM=30

# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Kite Connect (Zerodha)
KITE_API_KEY=
# Used only by scripts/kite_token_server.py to exchange request_token → access_token
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
# Optional: oauth helper defaults
# KITE_OAUTH_HOST=127.0.0.1
# KITE_OAUTH_PORT=8765
# KITE_OAUTH_CALLBACK_PATH=/kite/callback
# Set to 1 to log Python repr of api_key, request_token, api_secret on token exchange (stderr)
# KITE_OAUTH_DEBUG=0
